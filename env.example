API_PORT=4000
API_HOST=0.0.0.0
JWT_SECRET=change-me
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wave_hosting
REDIS_URL=redis://localhost:6379
REMOTE_AGENT_URL=http://127.0.0.1:7001

# Web UI → API (dev: separate processes). For the all-in-one image, set to empty string at build time so the browser calls /v1 on the same host (nginx → API).
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# ── Node agent: Docker + data (read by apps/node-agent) ─────────────────────
# Unraid / Linux production:
#   RUNTIME_DRIVER=docker
#   DOCKER_SOCKET_PATH=/var/run/docker.sock
#   SERVER_DATA_ROOT=/mnt/user/appdata/wave-hosting/servers
#
# Windows dev (local games with Java/Python — no Linux Steam binaries):
#   RUNTIME_DRIVER=process
#   Leave DOCKER_SOCKET_PATH unset — the agent uses the named pipe below automatically when you switch to docker mode.
#   For Docker Desktop on Windows (Linux containers for Source/Rust/etc.):
#   RUNTIME_DRIVER=docker
#   (Optional) DOCKER_SOCKET_PATH=//./pipe/docker_engine
#
SERVER_DATA_ROOT=
RUNTIME_DRIVER=process

# Only set to override auto-detection (Unix default: /var/run/docker.sock, Windows: Docker named pipe)
# DOCKER_SOCKET_PATH=

# Ubuntu — instant bootstrap (clone + optional “customize .env?” prompt + full install):
#   export WAVE_REPO_URL=https://github.com/OKiU-Network/bobshosting.git
#   curl -fsSL https://raw.githubusercontent.com/OKiU-Network/bobshosting/main/scripts/bootstrap.sh | sudo -E bash
# Or after clone: sudo bash scripts/bootstrap.sh
# Non-interactive (no prompts): WAVE_NONINTERACTIVE=1
# Ubuntu — install only (repo already on disk):
#   sudo bash scripts/ubuntu-first-install.sh
#
# All-in-one image (optional): build with
#   docker build -f infra/all-in-one/Dockerfile -t wave-hosting:aio .
# Run (Unraid / Linux): publish 8080, mount Docker socket + data dirs, e.g.
#   -v /var/run/docker.sock:/var/run/docker.sock
#   -v /mnt/user/appdata/wave-hosting/api-data:/app/apps/api/.data
#   -v /mnt/user/appdata/wave-hosting/servers:/var/lib/wave-hosting/servers
# Set RUNTIME_DRIVER=docker, SERVER_DATA_ROOT, JWT_SECRET via -e.
